# ============================================================
# AgentDecode — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Groq (Eval Scoring) ──────────────────────────────────────
# Free API key from https://console.groq.com/keys
# Used to auto-score LLM response quality (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your-groq-api-key

# ── Google Gemini (Error Diagnosis) ──────────────────────────
# Free API key from https://aistudio.google.com/apikey
# Used for AI-generated root cause analysis on error spans
GEMINI_API_KEY=your-gemini-api-key

# ── Resend (Alert Emails) ────────────────────────────────────
# Free API key from https://resend.com/api-keys (100 emails/day)
# Used to send alert notifications when thresholds are crossed
RESEND_API_KEY=re_your-resend-api-key

# ── Site URL (Optional) ──────────────────────────────────────
# Your deployment URL — used in SDK integration snippets
# Leave blank for localhost development
NEXT_PUBLIC_SITE_URL=
