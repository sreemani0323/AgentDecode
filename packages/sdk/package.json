{
  "name": "@agentdecode/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentDecode — AI agent observability. Trace LLM calls, tool executions, and agent workflows with zero config.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "observability",
    "tracing",
    "llm",
    "langchain",
    "openai",
    "monitoring",
    "evaluation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18"
  }
}
